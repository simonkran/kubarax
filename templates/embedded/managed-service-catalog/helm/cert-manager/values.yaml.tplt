cert-manager:
  installCRDs: true
  replicaCount: 1
  prometheus:
    enabled: {{ if eq (index .services "kubePrometheusStack").status "enabled" }}true{{ else }}false{{ end }}
    servicemonitor:
      enabled: {{ if eq (index .services "kubePrometheusStack").status "enabled" }}true{{ else }}false{{ end }}
  webhook:
    replicaCount: 1
  cainjector:
    replicaCount: 1
