flux2:
  installCRDs: true
  cli:
    image: ghcr.io/fluxcd/flux-cli
  helmController:
    create: true
  imageAutomationController:
    create: false
  imageReflectorController:
    create: false
  kustomizeController:
    create: true
  notificationController:
    create: true
  sourceController:
    create: true
