{{- if .projects }}
{{- range .projects }}
---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: tenant-{{ .name }}
  namespace: flux-system
spec:
  interval: 5m
  sourceRef:
    kind: GitRepository
    name: flux-system
  path: ./tenants/{{ .name }}
  prune: true
  serviceAccountName: flux-{{ .name }}
  targetNamespace: {{ .name }}
{{- end }}
{{- end }}
