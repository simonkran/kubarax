apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: platform
  namespace: flux-system
spec:
  interval: {{ .fluxcd.interval | default "5m" }}
  sourceRef:
    kind: GitRepository
    name: platform
  path: ./clusters/{{ .name }}
  prune: true
  wait: true
  timeout: 10m
  healthChecks: []
